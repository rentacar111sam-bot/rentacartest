# RentCar Production Environment Variables
# Bu faylni .env.production ga ko'chiring va qiymatlarni o'zgartiring

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=CHANGE-THIS-TO-RANDOM-SECRET-KEY-IN-PRODUCTION
JWT_SECRET_KEY=CHANGE-THIS-TO-RANDOM-JWT-SECRET-KEY-IN-PRODUCTION
JWT_ACCESS_TOKEN_EXPIRES=3600

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=5242880
UPLOAD_URL=https://your-domain.com/uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf
MAX_FILE_SIZE=5242880

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-THIS-PASSWORD-IN-PRODUCTION

# Security Configuration
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://api.your-domain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT=3600

# Site Configuration
SITE_URL=https://your-domain.com
SITE_NAME=RentCar

# MUHIM ESLATMALAR:
# 1. SECRET_KEY va JWT_SECRET_KEY ni o'zgartiring (random string)
# 2. ADMIN_PASSWORD ni kuchli parolga o'zgartiring
# 3. your-domain.com ni o'z domeningiz bilan almashtiring
# 4. UPLOAD_URL ni to'g'ri domen bilan yangilang
# 5. CORS_ORIGINS ga barcha kerakli domenlarni qo'shing
# 6. DATABASE_URL ni to'g'ri ma'lumotlar bazasi bilan almashtiring
# 7. Telegram bot token va chat ID larini o'zgartiring
